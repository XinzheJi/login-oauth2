<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.system.alarm.mapper.HistoryAlarmMapper">

    <resultMap id="HistoryAlarmResultMap" type="com.system.alarm.domain.entity.HistoryAlarmEntity">
        <id property="id" column="id"/>
        <result property="createUser" column="create_user"/>
        <result property="createTime" column="create_time"/>
        <result property="updateUser" column="update_user"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="name" column="name"/>
        <result property="areaId" column="area_id"/>
        <result property="code" column="code"/>
        <result property="levelId" column="level_id"/>
        <result property="alarmConfigId" column="alarm_config_id"/>
        <result property="alarmResourceType" column="alarm_resource_type"/>
        <result property="alarmResourceId" column="alarm_resource_id"/>
        <result property="alarmResourceName" column="alarm_resource_name"/>
        <result property="status" column="status"/>
        <result property="alarmSource" column="alarm_source"/>
        <result property="alarmSourceId" column="alarm_source_id"/>
        <result property="alarmValue" column="alarm_value"/>
        <result property="reAlarmSource" column="re_alarm_source"/>
        <result property="reAlarmSourceId" column="re_alarm_source_id"/>
        <result property="reAlarmValue" column="re_alarm_value"/>
        <result property="confirmStatus" column="confirm_status"/>
        <result property="confirmUser" column="confirm_user"/>
        <result property="confirmUserId" column="confirm_user_id"/>
        <result property="confirmTime" column="confirm_time"/>
        <result property="reason" column="reason"/>
        <result property="suggestion" column="suggestion"/>
        <result property="reAlarmTime" column="re_alarm_time"/>
        <result property="alarmResourceDetailsType" column="alarm_resource_details_type"/>
        <result property="alarmResourceDetailsName" column="alarm_resource_details_name"/>
        <result property="alarmResourceDetailsId" column="alarm_resource_details_id"/>
        <result property="alarmResourceDetailsIndex" column="alarm_resource_details_index"/>
        <result property="alarmType" column="alarm_type"/>
        <result property="tenantId" column="tenant_id"/>
    </resultMap>

    <sql id="HistoryAlarmColumns">
        id,
        create_user,
        create_time,
        update_user,
        update_time,
        remark,
        name,
        area_id,
        code,
        level_id,
        alarm_config_id,
        alarm_resource_type,
        alarm_resource_id,
        alarm_resource_name,
        status,
        alarm_source,
        alarm_source_id,
        alarm_value,
        re_alarm_source,
        re_alarm_source_id,
        re_alarm_value,
        confirm_status,
        confirm_user,
        confirm_user_id,
        confirm_time,
        reason,
        suggestion,
        re_alarm_time,
        alarm_resource_details_type,
        alarm_resource_details_name,
        alarm_resource_details_id,
        alarm_resource_details_index,
        alarm_type,
        tenant_id
    </sql>

    <sql id="HistoryAlarmWhere">
        <where>
            <if test="tenantId != null">
                AND tenant_id = #{tenantId}
            </if>
            <if test="query.areaId != null">
                AND area_id = #{query.areaId}
            </if>
            <if test="query.alarmResourceId != null">
                AND alarm_resource_id = #{query.alarmResourceId}
            </if>
            <if test="query.alarmResourceName != null and query.alarmResourceName != ''">
                AND alarm_resource_name LIKE CONCAT('%', #{query.alarmResourceName}, '%')
            </if>
            <if test="query.statusList != null and query.statusList.size() &gt; 0">
                AND status IN
                <foreach collection="query.statusList" item="status" open="(" separator="," close=")">
                    #{status}
                </foreach>
            </if>
            <if test="query.levelIds != null and query.levelIds.size() &gt; 0">
                AND level_id IN
                <foreach collection="query.levelIds" item="levelId" open="(" separator="," close=")">
                    #{levelId}
                </foreach>
            </if>
            <if test="query.alarmResourceType != null and query.alarmResourceType != ''">
                AND alarm_resource_type = #{query.alarmResourceType}
            </if>
            <if test="query.alarmSource != null and query.alarmSource != ''">
                AND alarm_source = #{query.alarmSource}
            </if>
            <if test="query.confirmStatus != null and query.confirmStatus != ''">
                AND confirm_status = #{query.confirmStatus}
            </if>
            <if test="query.alarmType != null and query.alarmType != ''">
                AND alarm_type = #{query.alarmType}
            </if>
            <if test="query.alarmStartTime != null">
                AND create_time &gt;= #{query.alarmStartTime}
            </if>
            <if test="query.alarmEndTime != null">
                AND create_time &lt;= #{query.alarmEndTime}
            </if>
            <if test="query.recoverStartTime != null">
                AND re_alarm_time &gt;= #{query.recoverStartTime}
            </if>
            <if test="query.recoverEndTime != null">
                AND re_alarm_time &lt;= #{query.recoverEndTime}
            </if>
        </where>
    </sql>

    <select id="countHistoryAlarms" resultType="long">
        SELECT COUNT(1)
        FROM history_alarm
        <include refid="HistoryAlarmWhere"/>
    </select>

    <select id="selectHistoryAlarms" resultMap="HistoryAlarmResultMap">
        SELECT
            <include refid="HistoryAlarmColumns"/>
        FROM history_alarm
        <include refid="HistoryAlarmWhere"/>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="selectHistoryAlarmById" resultMap="HistoryAlarmResultMap">
        SELECT
            <include refid="HistoryAlarmColumns"/>
        FROM history_alarm
        <where>
            id = #{id}
            <if test="tenantId != null">
                AND tenant_id = #{tenantId}
            </if>
        </where>
        LIMIT 1
    </select>

</mapper>
