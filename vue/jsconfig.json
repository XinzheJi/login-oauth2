{
  "compilerOptions": {
    "target": "es5",
    "module": "esnext",
    "baseUrl": "./",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "scripthost"
    ],
    "types": [
      "vue",
      "element-plus"
    ]
  },
  "include": [
    "src/**/*",
    "src/types/**/*",
    "node_modules/element-plus/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
